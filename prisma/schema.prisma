generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Faction {
  id          String       @id @default(cuid())
  bsdataId    String       @unique
  name        String
  description String?
  detachments Detachment[]
  units       Unit[]
  createdAt   DateTime     @default(now())
}

model Detachment {
  id              String        @id @default(cuid())
  bsdataId        String        @unique
  name            String
  factionId       String
  faction         Faction       @relation(fields: [factionId], references: [id])
  ruleName        String?
  ruleDescription String?       @db.Text
  enhancements    Enhancement[]
  armyLists       ArmyList[]
}

model Enhancement {
  id           String     @id @default(cuid())
  bsdataId     String     @unique
  name         String
  detachmentId String
  detachment   Detachment @relation(fields: [detachmentId], references: [id])
  points       Int
  description  String?    @db.Text
  /// e.g. "Captain model only" — parsed from description
  restriction  String?
}

model Unit {
  id               String         @id @default(cuid())
  bsdataId         String         @unique
  name             String
  factionId        String
  faction          Faction        @relation(fields: [factionId], references: [id])

  /// Base points cost (for minimum squad size)
  points           Int
  /// JSON array: [{minModels: 6, points: 170}] — cost tiers for larger squads
  scaledCosts      String         @default("[]")

  role             String         // Character, Battleline, Infantry, Vehicle, etc.
  keywords         String[]
  factionKeywords  String[]

  /// Stats
  movement         String?
  toughness        Int?
  save             String?
  wounds           Int?
  leadership       String?
  objectiveControl Int?
  invulnSave       String?

  /// Leader rules
  isLeader         Boolean        @default(false)
  /// Names of units this leader can be attached to
  leaderOf         String[]

  /// Squad size constraints
  minModels        Int            @default(1)
  maxModels        Int            @default(1)

  abilities        Ability[]
  weaponProfiles   WeaponProfile[]
  /// Structured weapon choices (sergeant options, squad specials, etc.)
  weaponOptions    WeaponOption[]
  armyListUnits    ArmyListUnit[]
}

model WeaponProfile {
  id          String   @id @default(cuid())
  bsdataId    String
  name        String
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id])
  weaponType  String   // "Ranged" or "Melee"
  range       String?
  attacks     String?
  /// BS for ranged, WS for melee
  skill       String?
  strength    String?
  armorPen    String?
  damage      String?
  keywords    String[]
}

/// A weapon choice slot on a unit
/// e.g. Sergeant Weapon 1: [Heavy Bolt Pistol, Plasma Pistol, Hand Flamer]
/// or   Special: w/ Plasma Pistol  (max 1, increases to 2 at 10 models)
model WeaponOption {
  id                   String  @id @default(cuid())
  bsdataId             String
  unitId               String
  unit                 Unit    @relation(fields: [unitId], references: [id])

  /// e.g. "Weapon 1", "Weapon 2", "Special: w/ Plasma Pistol", "Fixed Loadout"
  slotName             String
  /// "sergeant", "trooper", "special_model"
  modelType            String
  /// e.g. "Assault Intercessor Sergeant with Jump Pack"
  modelName            String
  /// Weapon names available in this slot
  choices              String[]
  minSelections        Int     @default(1)
  maxSelections        Int     @default(1)
  /// If squad size >= this, maxSelections increases to conditionalMax
  conditionalThreshold Int?
  conditionalMax       Int?
  defaultChoice        String?
}

model Ability {
  id          String  @id @default(cuid())
  bsdataId    String
  name        String
  unitId      String
  unit        Unit    @relation(fields: [unitId], references: [id])
  description String? @db.Text
}

model ArmyList {
  id           String         @id @default(cuid())
  name         String
  factionId    String
  detachmentId String
  detachment   Detachment     @relation(fields: [detachmentId], references: [id])
  pointsLimit  Int            @default(2000)
  units        ArmyListUnit[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ArmyListUnit {
  id         String   @id @default(cuid())
  armyListId String
  armyList   ArmyList @relation(fields: [armyListId], references: [id])
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id])
  modelCount Int      @default(5)
  notes      String?
}
